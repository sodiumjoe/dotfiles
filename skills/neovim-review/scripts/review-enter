#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "Usage: review-enter pr <number>" >&2
  echo "       review-enter branch [<base>]" >&2
  exit 1
}

json_out() {
  printf '{"mode":"%s","id":"%s","base_ref":"%s","head_ref":"%s","toplevel":"%s","stashed":%s,"previous_branch":"%s"}\n' \
    "$mode" "$id" "$base_ref" "$head_ref" "$toplevel" "$stashed" "$previous_branch"
}

[[ $# -lt 1 ]] && usage

mode="$1"
shift
toplevel=$(git rev-parse --show-toplevel 2>/dev/null) || { echo '{"error":"not a git repository"}'; exit 1; }
previous_branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")
stashed=false

stash_if_dirty() {
  if [[ -n "$(git status --porcelain 2>/dev/null)" ]]; then
    git stash push -m "review-enter auto-stash" || { echo '{"error":"git stash failed"}'; exit 1; }
    stashed=true
  fi
}

# Clean up any stale review cache
rm -rf "$toplevel/.review"
mkdir -p "$toplevel/.review"

if [[ "$mode" == "pr" ]]; then
  [[ $# -lt 1 ]] && usage
  pr_number="$1"
  id="$pr_number"

  pr_json=$(gh pr view "$pr_number" --json baseRefName,headRefName 2>/dev/null) || {
    echo '{"error":"gh pr view failed"}'
    exit 1
  }
  base_ref=$(echo "$pr_json" | jq -r '.baseRefName')
  head_ref_name=$(echo "$pr_json" | jq -r '.headRefName')
  head_ref="pr-$pr_number"

  stash_if_dirty

  # Detach HEAD first so we can delete+recreate the branch
  if [[ "$(git rev-parse --abbrev-ref HEAD 2>/dev/null)" == "$head_ref" ]]; then
    git checkout --detach HEAD 2>/dev/null || true
  fi
  git branch -D "$head_ref" 2>/dev/null || true
  git fetch origin "pull/$pr_number/head:$head_ref" || { echo '{"error":"PR fetch failed"}'; exit 1; }
  git checkout "$head_ref" || { echo '{"error":"PR checkout failed"}'; exit 1; }
  git fetch origin "$base_ref:refs/remotes/origin/$base_ref" 2>/dev/null || true

  # Cache diff, files, commits (all network/git I/O happens here)
  gh pr diff "$pr_number" > "$toplevel/.review/diff" 2>/dev/null || true
  gh pr diff "$pr_number" --name-only > "$toplevel/.review/files" 2>/dev/null || true
  gh pr view "$pr_number" --json commits --jq '.commits[] | "\(.oid) \(.messageHeadline)"' > "$toplevel/.review/commits" 2>/dev/null || true

elif [[ "$mode" == "branch" ]]; then
  base_ref="${1:-}"
  head_ref="HEAD"
  id=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "HEAD")

  if [[ -z "$base_ref" ]]; then
    if remote_head=$(git rev-parse --abbrev-ref origin/HEAD 2>/dev/null); then
      base_ref="${remote_head#origin/}"
    fi
  fi

  if [[ -z "$base_ref" ]]; then
    root=$(git rev-parse --show-toplevel 2>/dev/null)
    for ns in pay-server zoolander gocode; do
      if [[ -d "$root/$ns" ]]; then
        ref="green-$ns"
        if git rev-parse --verify "origin/$ref" &>/dev/null; then
          base_ref="origin/$ref"
          break
        elif git rev-parse --verify "$ref" &>/dev/null; then
          base_ref="$ref"
          break
        fi
      fi
    done
  fi

  if [[ -z "$base_ref" ]]; then
    for candidate in main master; do
      if git rev-parse --verify "$candidate" &>/dev/null; then
        base_ref="$candidate"
        break
      elif git rev-parse --verify "origin/$candidate" &>/dev/null; then
        base_ref="origin/$candidate"
        break
      fi
    done
  fi

  if [[ -z "$base_ref" ]]; then
    echo '{"error":"could not detect base branch"}'
    exit 1
  fi

  merge_base=$(git merge-base "$base_ref" HEAD 2>/dev/null || echo "$base_ref")
  base_ref="$merge_base"

  stash_if_dirty

  # Cache diff, files, commits
  git diff --no-renames "$base_ref..HEAD" > "$toplevel/.review/diff" 2>/dev/null || true
  git diff --no-renames --name-only "$base_ref..HEAD" > "$toplevel/.review/files" 2>/dev/null || true
  git log --reverse --format='%H %s' "$base_ref..HEAD" > "$toplevel/.review/commits" 2>/dev/null || true

else
  usage
fi

# Initialize neovim session state with cached data
nvim_lua="$(dirname "$0")/nvim-lua"
if [[ -x "$nvim_lua" ]]; then
  # Escape single quotes in variables for Lua string literals
  escape() { printf '%s' "$1" | sed "s/'/\\\\'/g"; }

  id_esc=$(escape "$id")
  mode_esc=$(escape "$mode")
  base_esc=$(escape "$base_ref")
  head_esc=$(escape "$head_ref")
  top_esc=$(escape "$toplevel")
  prev_esc=$(escape "$previous_branch")

  "$nvim_lua" "
local review = require('sodium.review')

-- Start session
review.start_session({
  id = '$id_esc',
  mode = '$mode_esc',
  base_ref = '$base_esc',
  head_ref = '$head_esc',
  toplevel = '$top_esc',
})
review.set_previous_branch('$prev_esc')
review.set_stashed($stashed)

-- Parse cached diff into per-file diffs
local toplevel = '$top_esc'
local diff_path = toplevel .. '/.review/diff'
local f = io.open(diff_path, 'r')
if f then
  local diff_text = f:read('*a')
  f:close()
  local file_diffs = review.parse_file_diffs(diff_text)
  review.set_file_diffs(file_diffs)
end

-- Build file list from cached files, filtered by existence
local files_path = toplevel .. '/.review/files'
local ff = io.open(files_path, 'r')
local items = {}
if ff then
  local i = 0
  for line in ff:lines() do
    if line ~= '' then
      i = i + 1
      local abs = toplevel .. '/' .. line
      items[#items + 1] = {
        text = line,
        file = abs,
        rel = line,
        sort_idx = i,
        exists = vim.fn.filereadable(abs) == 1,
        reviewed = false,
      }
    end
  end
  ff:close()
end
review.set_files(items)

-- PR mode: set user and load existing comments
if '$mode_esc' == 'pr' then
  local user = vim.trim(vim.system({'gh', 'api', 'user', '--jq', '.login'}, {text=true}):wait().stdout or '')
  review.set_current_user(user)
  vim.g.comment_overlay_actor = user

  local s = review.get_session()
  local r = vim.system({'gh', 'api', 'repos/{owner}/{repo}/pulls/' .. s.id .. '/comments', '--paginate'}, {text=true}):wait()
  if r.code == 0 and r.stdout ~= '' then
    local by_id, files = review.parse_gh_comments(r.stdout)
    if next(by_id) then
      review.write_comments_json(toplevel .. '/.nvim-comments.json', review.build_comments_v2(by_id, files))
      pcall(vim.cmd, 'CommentRefresh')
    end
  end
end

return 0
" 2>/dev/null || true
fi

json_out
