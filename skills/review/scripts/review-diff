#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "Usage: review-diff <base-ref> [<file>]" >&2
  echo "       review-diff --pr <number> <base-ref> [<file>]" >&2
  exit 1
}

[[ $# -lt 1 ]] && usage

pr_number=""
if [[ "$1" == "--pr" ]]; then
  [[ $# -lt 3 ]] && usage
  pr_number="$2"
  shift 2
fi

base_ref="$1"
shift

if [[ $# -ge 1 ]]; then
  # Per-file diff — git with path scoping is fast regardless of mode
  git diff --no-renames "$base_ref..HEAD" -- "$1"
elif [[ -n "$pr_number" ]]; then
  # Full PR diff — use gh (server-side, avoids massive local tree walk)
  gh pr diff "$pr_number"
else
  # Full branch diff — git with --no-renames to skip expensive rename detection
  git diff --no-renames "$base_ref..HEAD"
fi
