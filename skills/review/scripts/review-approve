#!/usr/bin/env bash
# Submit a PR review and clean up.
# Usage: review-approve [APPROVE|REQUEST_CHANGES|COMMENT]
# Called from neovim keybinding — reads session state via nvim-lua.
set -euo pipefail

event="${1:-APPROVE}"

nvim_lua="$(dirname "$0")/nvim-lua"
[[ ! -x "$nvim_lua" ]] && { echo "nvim-lua not found" >&2; exit 1; }

# Read session state from neovim
state=$("$nvim_lua" "
local r = require('sodium.review')
local s = r.get_session()
if not s then return 'ERROR:no session' end
local parts = {
  'id=' .. (s.id or ''),
  'mode=' .. (s.mode or ''),
  'toplevel=' .. (s.toplevel or ''),
  'previous=' .. (r.get_previous_branch() or ''),
  'stashed=' .. tostring(r.is_stashed()),
  'user=' .. (r.get_current_user() or ''),
}
return table.concat(parts, '\n')
")

if [[ "$state" == *"ERROR:"* ]]; then
  echo "${state#*ERROR:}" >&2
  exit 1
fi

# Parse state
id=""; mode=""; toplevel=""; previous=""; stashed="false"; user=""
while IFS='=' read -r key val; do
  case "$key" in
    id) id="$val" ;;
    mode) mode="$val" ;;
    toplevel) toplevel="$val" ;;
    previous) previous="$val" ;;
    stashed) stashed="$val" ;;
    user) user="$val" ;;
  esac
done <<< "$state"

if [[ "$mode" != "pr" ]]; then
  echo "Not in PR mode" >&2
  exit 1
fi

scripts_dir="$(dirname "$0")"

# Extract local comments from .nvim-comments.json BEFORE cleanup
comments="[]"
comments_file="$toplevel/.nvim-comments.json"
if [[ -f "$comments_file" && -n "$user" ]]; then
  comments=$(jq --arg user "$user" '
    [.comments | to_entries[]
     | select(.value.actor == $user or .value.author == $user)
     | select(.key | test("^[0-9]+$") | not)
     | .value]
  ' "$comments_file" 2>/dev/null || echo "[]")
fi

# Submit review FIRST (while still on PR branch, gh context intact)
echo "$comments" | "$scripts_dir/review-submit" "$id" "$event" ""

# THEN clean up
"$scripts_dir/review-exit" "$toplevel" \
  ${previous:+--restore-branch "$previous"} \
  $([[ "$stashed" == "true" ]] && echo "--pop-stash")

echo "PR #$id — $event"
