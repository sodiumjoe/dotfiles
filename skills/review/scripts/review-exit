#!/usr/bin/env bash
set -euo pipefail

if [[ $# -lt 1 ]]; then
  echo "Usage: review-exit <toplevel> [--restore-branch <branch>] [--pop-stash]" >&2
  exit 1
fi

toplevel="$1"
shift

restore_branch=""
pop_stash=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --restore-branch) restore_branch="$2"; shift 2 ;;
    --pop-stash) pop_stash=true; shift ;;
    *) shift ;;
  esac
done

# Clean up cached review data
rm -rf "$toplevel/.review"
rm -f "$toplevel/.nvim-comments.json"

# Reset neovim session state
nvim_lua="$(dirname "$0")/nvim-lua"
if [[ -x "$nvim_lua" ]]; then
  "$nvim_lua" "pcall(vim.cmd, 'CommentRefresh') require('sodium.review').reset() return 0" 2>/dev/null || true
fi

# Restore previous branch
if [[ -n "$restore_branch" ]]; then
  git checkout "$restore_branch" >/dev/null 2>/dev/null || true
fi

# Pop stash if we auto-stashed on enter
if [[ "$pop_stash" == "true" ]]; then
  git stash pop 2>/dev/null || echo '{"warning":"stash pop failed"}' >&2
fi
