#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "Usage: review-picker <base-ref> <head-ref>" >&2
  echo "       review-picker --pr <number> <base-ref> <head-ref>" >&2
  exit 1
}

[[ $# -lt 2 ]] && usage

pr_number=""
if [[ "$1" == "--pr" ]]; then
  [[ $# -lt 4 ]] && usage
  pr_number="$2"
  shift 2
fi

base_ref="$1"
head_ref="$2"

nvim_lua="$(dirname "$0")/../../neovim/scripts/nvim-lua"
[[ ! -x "$nvim_lua" ]] && { echo "nvim-lua not found"; exit 1; }

escape() { printf '%s' "$1" | sed "s/'/\\\\'/g"; }

base_esc=$(escape "$base_ref")
head_esc=$(escape "$head_ref")
pr_esc=$(escape "$pr_number")

"$nvim_lua" "
local review = require('sodium.review')
local diff_mod = require('sodium.diff')
local utils = require('sodium.utils')

local session = review.get_session()
if not session then
  vim.notify('No review session active', vim.log.levels.WARN)
  return 0
end

local base_ref = '$base_esc'
local head_ref = '$head_esc'
local pr_number = '$pr_esc'
local toplevel = session.toplevel or ''
local is_pr = pr_number ~= ''

-- Get file list
local result
if is_pr then
  result = vim.system({ 'gh', 'pr', 'diff', pr_number, '--name-only' }, { text = true }):wait()
else
  result = vim.system({ 'git', 'diff', '--no-renames', '--name-only', base_ref .. '..' .. head_ref }, { text = true }):wait()
end
if result.code ~= 0 then
  vim.notify('diff failed: ' .. (result.stderr or ''), vim.log.levels.ERROR)
  return 0
end

-- Diff cache: fetched async for PR mode, lazily per-file for branch mode
local file_diffs = {}
local diff_loaded = false
local diff_loading = false

local function load_full_diff(cb)
  if diff_loaded or diff_loading then return end
  diff_loading = true
  local cmd
  if is_pr then
    cmd = { 'gh', 'pr', 'diff', pr_number }
  else
    cmd = { 'git', 'diff', '--no-renames', base_ref .. '..' .. head_ref }
  end
  vim.system(cmd, { text = true }, function(r)
    vim.schedule(function()
      if r.code == 0 then
        file_diffs = review.parse_file_diffs(r.stdout)
      end
      diff_loaded = true
      diff_loading = false
      if cb then cb() end
    end)
  end)
end

-- Start loading diffs immediately in background
load_full_diff()

local files = {}
for line in (result.stdout or ''):gmatch('[^\\n]+') do
  if line ~= '' then
    files[#files + 1] = line
  end
end

if #files == 0 then
  vim.notify('No changed files', vim.log.levels.INFO)
  return 0
end

local items = {}
for i, filepath in ipairs(files) do
  local abs = toplevel ~= '' and (toplevel .. '/' .. filepath) or filepath
  items[#items + 1] = {
    text = filepath,
    file = abs,
    rel = filepath,
    sort_idx = i,
    reviewed = review.is_reviewed(filepath),
  }
end

local title = session.mode == 'pr'
  and string.format('PR #%s Files', session.id)
  or string.format('Review: %s', session.id)

Snacks.picker({
  title = title,
  items = items,
  preview = function(ctx)
    local item = ctx.item
    if not item then return end
    local cached = file_diffs[item.rel]
    if cached then
      ctx.preview:set_lines(vim.split(cached, '\\n'))
      ctx.preview:highlight({ ft = 'diff' })
      return
    end
    if diff_loaded then
      ctx.preview:set_lines({ 'No diff available' })
      return
    end
    ctx.preview:set_lines({ 'Loading diff...' })
    load_full_diff(function()
      local current = ctx.picker:current()
      if current and current.rel == item.rel then
        local d = file_diffs[item.rel]
        if d then
          ctx.preview:set_lines(vim.split(d, '\\n'))
          ctx.preview:highlight({ ft = 'diff' })
        else
          ctx.preview:set_lines({ 'No diff available' })
        end
      end
    end)
  end,
  sort = function(a, b)
    if a.score ~= b.score then return a.score > b.score end
    return a.sort_idx < b.sort_idx
  end,
  format = function(item)
    local marker = item.reviewed and '[x] ' or '[ ] '
    local hl = item.reviewed and 'SnacksPickerComment' or 'SnacksPickerDir'
    return { { marker, hl }, { item.rel } }
  end,
  on_show = function() vim.cmd.stopinsert() end,
  win = {
    input = {
      keys = {
        ['<Tab>'] = { 'toggle_reviewed', mode = { 'n', 'i' } },
        ['<C-o>'] = { 'open_file', mode = { 'n', 'i' } },
      },
    },
  },
  confirm = function(picker, item)
    if not item then return end
    picker:close()
    vim.schedule(function()
      diff_mod.open({
        mode = 'refs',
        file = item.file,
        left_ref = base_ref,
        right_ref = head_ref,
      })
    end)
  end,
  actions = {
    toggle_reviewed = function(picker)
      local item = picker:current()
      if not item then return end
      review.toggle_reviewed(item.rel)
      item.reviewed = review.is_reviewed(item.rel)
      picker.list:update({ force = true })
    end,
    open_file = function(picker)
      local item = picker:current()
      if not item then return end
      picker:close()
      vim.schedule(function()
        local win = utils.editor_window()
        if win then vim.api.nvim_set_current_win(win) end
        utils.close_non_agentic_windows()
        vim.cmd.edit(item.file)
      end)
    end,
  },
})
return 0
"
