#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "Usage: review-commits <base-ref>" >&2
  echo "       review-commits --pr <number>" >&2
  exit 1
}

[[ $# -lt 1 ]] && usage

if [[ "$1" == "--pr" ]]; then
  [[ $# -lt 2 ]] && usage
  pr_number="$2"

  commits=$(gh pr view "$pr_number" --json commits --jq '.commits[] | "\(.oid) \(.messageHeadline)"' 2>/dev/null)
  if [[ -z "$commits" ]]; then
    echo '{"error":"no commits found"}'
    exit 0
  fi

  while IFS= read -r line; do
    sha="${line%% *}"
    subject="${line#* }"
    subject_escaped=$(printf '%s' "$subject" | sed 's/\\/\\\\/g; s/"/\\"/g')
    git diff-tree --no-commit-id --name-only -r "$sha" | while IFS= read -r file; do
      file_escaped=$(printf '%s' "$file" | sed 's/\\/\\\\/g; s/"/\\"/g')
      printf '{"commit":"%s","subject":"%s","file":"%s"}\n' "$sha" "$subject_escaped" "$file_escaped"
    done
  done <<< "$commits"

else
  base_ref="$1"

  commits=$(git log --reverse --format='%H %s' "$base_ref..HEAD" 2>/dev/null)
  if [[ -z "$commits" ]]; then
    echo '{"error":"no commits found"}'
    exit 0
  fi

  while IFS= read -r line; do
    sha="${line%% *}"
    subject="${line#* }"
    subject_escaped=$(printf '%s' "$subject" | sed 's/\\/\\\\/g; s/"/\\"/g')
    git diff-tree --no-commit-id --name-only -r "$sha" | while IFS= read -r file; do
      file_escaped=$(printf '%s' "$file" | sed 's/\\/\\\\/g; s/"/\\"/g')
      printf '{"commit":"%s","subject":"%s","file":"%s"}\n' "$sha" "$subject_escaped" "$file_escaped"
    done
  done <<< "$commits"
fi
