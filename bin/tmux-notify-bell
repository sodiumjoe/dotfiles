#!/bin/bash

TITLE="$1"
ZWS=$'\xe2\x80\x8b'
APP_NAME="${NOTIFY_AGENT_NAME:-Agent}"

case "$TITLE" in
  *"$ZWS"*)
    CLEAN="${TITLE//$ZWS/}"
    LABEL="${CLEAN#󰌗 }"
    MSG="$APP_NAME is waiting for input"
    osascript -e "display notification \"${MSG//\"/\\\"}\" with title \"${APP_NAME//\"/\\\"}\" subtitle \"${LABEL//\"/\\\"}\""
    ;;
esac