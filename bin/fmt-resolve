#!/usr/bin/env bash
set -euo pipefail

exec_mode=false
stdin_mode=false
while [[ "${1:-}" == --* ]]; do
  case "$1" in
    --exec) exec_mode=true; shift ;;
    --stdin) stdin_mode=true; shift ;;
    *) shift ;;
  esac
done

[[ -z "${1:-}" ]] && exit 0
file="$1"

find_up() {
  local dir="$1" name="$2"
  while [[ "$dir" != "/" ]]; do
    [[ -e "$dir/$name" ]] && echo "$dir" && return 0
    dir=$(dirname "$dir")
  done
  return 1
}

filedir=$(cd "$(dirname "$file")" 2>/dev/null && pwd || dirname "$file")
basename=$(basename "$file")
cmd=()

case "${basename##*.}" in
  lua)
    command -v stylua &>/dev/null || exit 0
    if $stdin_mode; then
      cmd=(stylua --search-parent-directories --stdin-filepath "$file" -)
    else
      cmd=(stylua --search-parent-directories "$file")
    fi
    ;;
  js|ts|jsx|tsx|css|json)
    prettier_dir=$(find_up "$filedir" "node_modules/.bin/prettier") || true
    if [[ -n "${prettier_dir:-}" ]]; then
      prettier_bin="$prettier_dir/node_modules/.bin/prettier"
    else
      prettier_bin=$(command -v prettier 2>/dev/null || echo "")
    fi
    [[ -z "$prettier_bin" ]] && exit 0
    eslint_bin=""
    case "${basename##*.}" in
      js|ts|jsx|tsx)
        eslint_dir=$(find_up "$filedir" "node_modules/.bin/eslint") || true
        if [[ -n "${eslint_dir:-}" ]]; then
          eslint_bin="$eslint_dir/node_modules/.bin/eslint"
        fi
        ;;
    esac
    if $stdin_mode; then
      if [[ -n "$eslint_bin" ]]; then
        tmp=$(mktemp --suffix=".${basename##*.}")
        trap 'rm -f "$tmp"' EXIT
        cat > "$tmp"
        "$eslint_bin" --fix --no-error-on-unmatched-pattern "$tmp" 2>/dev/null || true
        exec "$prettier_bin" --stdin-filepath "$file" < "$tmp"
      else
        cmd=("$prettier_bin" --stdin-filepath "$file")
      fi
    else
      if [[ -n "$eslint_bin" ]]; then
        "$eslint_bin" --fix --no-error-on-unmatched-pattern "$file" 2>/dev/null || true
      fi
      cmd=("$prettier_bin" --write "$file")
    fi
    ;;
  bzl|bazel|BUILD)
    root=$(find_up "$filedir" "scripts/dev/buildifier") || exit 0
    if $stdin_mode; then
      cmd=("$root/scripts/dev/buildifier" -mode=fix -stdin -path "$file")
    else
      cmd=("$root/scripts/dev/buildifier" "$file")
    fi
    ;;
  rb)
    root=$(find_up "$filedir" "scripts/bin/rubocop-server/rubocop") || exit 0
    if $stdin_mode; then
      "$root/scripts/bin/rubocop-server/rubocop" --autocorrect --stdin "$file" 2>/dev/null \
        | sed -n '/^====================$/,$ { /^====================$/d; p; }' \
        | sed -z 's/\n\n1\n\n$/\n/'
      exit 0
    else
      cmd=("$root/scripts/bin/rubocop-server/rubocop" --autocorrect "$file")
    fi
    ;;
esac

[[ ${#cmd[@]} -eq 0 ]] && exit 0

if $exec_mode || $stdin_mode; then
  exec "${cmd[@]}"
else
  printf '%q ' "${cmd[@]}"
  echo
fi