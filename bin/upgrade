#!/usr/bin/env bash
set -euo pipefail

DEVBOX_INIT="${DEVBOX_INIT_PATH:-$HOME/stripe/devbox/.devbox-init}"
DOTFILES="${DOTFILES_ROOT:-$HOME/.dotfiles}"

declare -A DEVBOX_PINS=(
  [neovim]=NVIM_VERSION
  [lua-language-server]=LUA_LS_VERSION
  [efm-langserver]=EFM_VERSION
)

# npm packages shared between global install and devbox node-bin
DEVBOX_NPM_PACKAGES=(
  typescript
  typescript-language-server
  vscode-langservers-extracted
  @vtsls/language-server
  @agentclientprotocol/claude-agent-acp
  @typescript/native-preview
  tree-sitter-cli
)

usage() {
  cat <<EOF
Usage: upgrade [options] [formula ...]

Modes:
  upgrade                    Interactive: fzf multi-select from outdated packages
  upgrade <formula> [...]    Upgrade specific brew formulae + sync devbox pins
  upgrade --npm              Update global npm packages (devbox-tracked)
  upgrade --nvim             Update nvim plugins (Lazy update) + commit lockfile
  upgrade --all              Upgrade everything (brew + npm + nvim + devbox pins)
  upgrade --dry-run          Show what's outdated without doing anything

Options:
  --npm        Update npm packages only
  --nvim       Update neovim plugins only
  --all        Upgrade all brew + npm + nvim plugins
  --dry-run    Show outdated packages without upgrading
  -h, --help   Show this help
EOF
}

# Parse arguments
MODE=""
DRY_RUN=false
FORMULAE=()

for arg in "$@"; do
  case "$arg" in
    --npm) MODE="npm" ;;
    --nvim) MODE="nvim" ;;
    --all) MODE="all" ;;
    --dry-run) DRY_RUN=true ;;
    -h|--help) usage; exit 0 ;;
    -*) echo "Unknown option: $arg"; usage; exit 1 ;;
    *) FORMULAE+=("$arg") ;;
  esac
done

if [[ ${#FORMULAE[@]} -gt 0 ]]; then
  MODE="specific"
elif [[ -z "$MODE" ]]; then
  MODE="interactive"
fi

get_brew_outdated() {
  HOMEBREW_NO_AUTO_UPDATE=1 brew outdated --json=v2 2>/dev/null
}

get_brew_version() {
  local formula="$1"
  brew info --json=v2 "$formula" 2>/dev/null | python3 -c "
import json, sys
d = json.load(sys.stdin)
for f in d.get('formulae', []):
  if f.get('installed'):
    print(f['installed'][0]['version'])
    break
"
}

update_devbox_pin() {
  local formula="$1"
  local new_version="$2"

  if [[ ! -v "DEVBOX_PINS[$formula]" ]]; then
    return
  fi

  local var_name="${DEVBOX_PINS[$formula]}"

  if [[ ! -f "$DEVBOX_INIT" ]]; then
    echo "  warning: $DEVBOX_INIT not found, skipping devbox pin update"
    return
  fi

  local current_pin
  current_pin=$(grep -oP "${var_name}=\"?\K[^\"]*" "$DEVBOX_INIT" 2>/dev/null || true)

  if [[ -z "$current_pin" ]]; then
    echo "  warning: ${var_name} not found in $DEVBOX_INIT"
    return
  fi

  # Preserve v-prefix convention
  local new_pin="$new_version"
  if [[ "$current_pin" == v* ]]; then
    new_pin="v${new_version#v}"
  else
    new_pin="${new_version#v}"
  fi

  if [[ "$current_pin" == "$new_pin" ]]; then
    return
  fi

  sed -i '' "s|${var_name}=\"${current_pin}\"|${var_name}=\"${new_pin}\"|" "$DEVBOX_INIT"
  echo "  devbox: ${var_name} ${current_pin} → ${new_pin}"
}

do_brew_upgrade() {
  local formula="$1"
  echo "upgrading: $formula"
  brew upgrade "$formula" 2>&1 | tail -3
  local new_version
  new_version=$(get_brew_version "$formula")
  update_devbox_pin "$formula" "$new_version"
}

do_nvim_update() {
  echo "updating nvim plugins..."
  nvim --headless "+Lazy! update" +qa 2>&1 || true

  if git -C "$DOTFILES" diff --quiet lazy-lock.json 2>/dev/null; then
    echo "  no plugin changes"
  else
    git -C "$DOTFILES" add lazy-lock.json
    git -C "$DOTFILES" commit -m "upgrade nvim plugins"
    echo "  committed lazy-lock.json"
  fi
}

do_npm_update() {
  echo "updating npm packages (devbox-tracked)..."
  npm install -g "${DEVBOX_NPM_PACKAGES[@]}" 2>&1 | grep -E "^(added|updated|changed)" || true
  echo "  done"
}

get_npm_outdated() {
  # npm outdated exits non-zero when packages are outdated
  local raw
  raw=$(npm outdated -g --json 2>/dev/null || true)
  echo "$raw" | python3 -c "
import json, sys
tracked = set(sys.argv[1:])
d = json.load(sys.stdin) if sys.stdin.read else {}
" 2>/dev/null || echo "{}"
}

show_npm_outdated() {
  local raw
  raw=$(npm outdated -g --json 2>/dev/null || true)
  if [[ -z "$raw" || "$raw" == "{}" ]]; then
    echo "npm (devbox-tracked): all up to date"
    return
  fi

  local tracked
  tracked=$(printf '%s\n' "${DEVBOX_NPM_PACKAGES[@]}")
  local lines
  lines=$(echo "$raw" | python3 -c "
import json, sys
tracked = set(line.strip() for line in sys.stdin.readline() if line.strip()) if False else set()
" 2>/dev/null || true)

  # Simpler approach: filter with python
  lines=$(echo "$raw" | python3 -c "
import json, sys
tracked = [$(printf '"%s",' "${DEVBOX_NPM_PACKAGES[@]}")]
d = json.load(sys.stdin)
found = []
for name, info in d.items():
    if name in tracked:
        found.append(f\"  {name}: {info['current']} → {info['latest']}\")
if found:
    print(f'npm outdated ({len(found)}):')
    print('\n'.join(found))
else:
    print('npm (devbox-tracked): all up to date')
")
  echo "$lines"
}

show_outdated() {
  local json
  json=$(get_brew_outdated)

  local formulae
  formulae=$(echo "$json" | python3 -c "
import json, sys
d = json.load(sys.stdin)
for f in d.get('formulae', []):
    current = ', '.join(f.get('installed_versions', []))
    latest = f.get('current_version', '?')
    print(f\"{f['name']}\t{current} → {latest}\")
")

  if [[ -n "$formulae" ]]; then
    local count
    count=$(echo "$formulae" | wc -l | tr -d ' ')
    echo "Brew outdated ($count):"
    echo "$formulae" | column -t -s $'\t' | sed 's/^/  /'
  else
    echo "Brew: all up to date"
  fi

  echo ""
  show_npm_outdated

  echo ""

  # Nvim plugin staleness
  local last_commit
  last_commit=$(git -C "$DOTFILES" log -1 --format=%ct lazy-lock.json 2>/dev/null || echo 0)
  local now
  now=$(date +%s)
  local days_since=$(( (now - last_commit) / 86400 ))
  if [[ $days_since -gt 14 ]]; then
    echo "Nvim plugins: last updated ${days_since} days ago (stale)"
  else
    echo "Nvim plugins: last updated ${days_since} days ago"
  fi
}

# --- Main ---

case "$MODE" in
  interactive)
    if $DRY_RUN; then
      show_outdated
      exit 0
    fi

    json=$(get_brew_outdated)

    lines=$(echo "$json" | python3 -c "
import json, sys
d = json.load(sys.stdin)
for f in d.get('formulae', []):
    current = ', '.join(f.get('installed_versions', []))
    latest = f.get('current_version', '?')
    print(f\"{f['name']}\t{current} → {latest}\")
")

    # Add npm packages as selectable items
    npm_outdated=$(npm outdated -g --json 2>/dev/null || true)
    if [[ -n "$npm_outdated" && "$npm_outdated" != "{}" ]]; then
      npm_lines=$(echo "$npm_outdated" | python3 -c "
import json, sys
tracked = [$(printf '"%s",' "${DEVBOX_NPM_PACKAGES[@]}")]
d = json.load(sys.stdin)
for name, info in d.items():
    if name in tracked:
        print(f\"[npm] {name}\t{info['current']} → {info['latest']}\")
")
      if [[ -n "$npm_lines" ]]; then
        lines="${lines}"$'\n'"${npm_lines}"
      fi
    fi

    # Add nvim plugins as an option
    last_commit=$(git -C "$DOTFILES" log -1 --format=%ct lazy-lock.json 2>/dev/null || echo 0)
    now=$(date +%s)
    days_since=$(( (now - last_commit) / 86400 ))
    lines="${lines}"$'\n'"[nvim-plugins]	last updated ${days_since} days ago"

    selected=$(echo "$lines" | fzf --multi --header="Select packages to upgrade (TAB to multi-select)" | cut -f1)

    if [[ -z "$selected" ]]; then
      echo "Nothing selected."
      exit 0
    fi

    devbox_changed=false
    npm_to_update=()

    while IFS= read -r item; do
      if [[ "$item" == "[nvim-plugins]" ]]; then
        do_nvim_update
      elif [[ "$item" == "[npm] "* ]]; then
        pkg="${item#\[npm\] }"
        npm_to_update+=("$pkg")
      else
        do_brew_upgrade "$item"
        if [[ -v "DEVBOX_PINS[$item]" ]]; then
          devbox_changed=true
        fi
      fi
    done <<< "$selected"

    if [[ ${#npm_to_update[@]} -gt 0 ]]; then
      echo "updating npm packages: ${npm_to_update[*]}"
      npm install -g "${npm_to_update[@]}" 2>&1 | grep -E "^(added|updated|changed)" || true
    fi

    if $devbox_changed && [[ -f "$DEVBOX_INIT" ]]; then
      pushd "$(dirname "$DEVBOX_INIT")" > /dev/null
      if ! git diff --quiet .devbox-init 2>/dev/null; then
        git add .devbox-init
        git commit -m "upgrade devbox tool versions"
        echo "committed .devbox-init"
      fi
      popd > /dev/null
    fi
    ;;

  specific)
    if $DRY_RUN; then
      for formula in "${FORMULAE[@]}"; do
        echo "$formula: $(get_brew_version "$formula") → $(brew info --json=v2 "$formula" 2>/dev/null | python3 -c "import json,sys; d=json.load(sys.stdin); print(d['formulae'][0]['versions']['stable'])" 2>/dev/null || echo '?')"
      done
      exit 0
    fi

    devbox_changed=false
    for formula in "${FORMULAE[@]}"; do
      do_brew_upgrade "$formula"
      if [[ -v "DEVBOX_PINS[$formula]" ]]; then
        devbox_changed=true
      fi
    done

    if $devbox_changed && [[ -f "$DEVBOX_INIT" ]]; then
      pushd "$(dirname "$DEVBOX_INIT")" > /dev/null
      if ! git diff --quiet .devbox-init 2>/dev/null; then
        git add .devbox-init
        git commit -m "upgrade devbox tool versions"
        echo "committed .devbox-init"
      fi
      popd > /dev/null
    fi
    ;;

  npm)
    if $DRY_RUN; then
      show_npm_outdated
      exit 0
    fi
    do_npm_update
    ;;

  nvim)
    if $DRY_RUN; then
      last_commit=$(git -C "$DOTFILES" log -1 --format=%ct lazy-lock.json 2>/dev/null || echo 0)
      now=$(date +%s)
      days_since=$(( (now - last_commit) / 86400 ))
      echo "Nvim plugins: last updated ${days_since} days ago"
      exit 0
    fi
    do_nvim_update
    ;;

  all)
    if $DRY_RUN; then
      show_outdated
      exit 0
    fi

    echo "=== brew upgrade ==="
    brew update
    outdated=$(HOMEBREW_NO_AUTO_UPDATE=1 brew outdated --quiet 2>/dev/null || true)
    if [[ -n "$outdated" ]]; then
      while IFS= read -r formula; do
        do_brew_upgrade "$formula"
      done <<< "$outdated"
    else
      echo "all up to date"
    fi

    if [[ -f "$DEVBOX_INIT" ]]; then
      pushd "$(dirname "$DEVBOX_INIT")" > /dev/null
      if ! git diff --quiet .devbox-init 2>/dev/null; then
        git add .devbox-init
        git commit -m "upgrade devbox tool versions"
        echo "committed .devbox-init"
      fi
      popd > /dev/null
    fi

    echo ""
    echo "=== npm packages ==="
    do_npm_update

    echo ""
    echo "=== nvim plugins ==="
    do_nvim_update
    ;;
esac