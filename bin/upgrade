#!/usr/bin/env bash
set -euo pipefail

# Upgrade specific brew formulae and sync devbox version pins.
# Called by work tick when the user checks items in the daily note's ## Upgrades section.

DEVBOX_INIT="${DEVBOX_INIT_PATH:-$HOME/stripe/devbox/.devbox-init}"

declare -A DEVBOX_PINS=(
  [neovim]=NVIM_VERSION
  [lua-language-server]=LUA_LS_VERSION
  [efm-langserver]=EFM_VERSION
  [unison]=UNISON_VERSION
)

usage() {
  echo "Usage: upgrade <formula> [formula ...]"
  echo "Upgrades brew formulae and syncs devbox version pins."
}

if [[ $# -eq 0 ]]; then
  usage
  exit 1
fi

get_brew_version() {
  local formula="$1"
  brew info --json=v2 "$formula" 2>/dev/null | python3 -c "
import json, sys
d = json.load(sys.stdin)
for f in d.get('formulae', []):
  if f.get('installed'):
    print(f['installed'][0]['version'])
    break
"
}

update_devbox_pin() {
  local formula="$1"
  local new_version="$2"

  if [[ ! -v "DEVBOX_PINS[$formula]" ]]; then
    return
  fi

  local var_name="${DEVBOX_PINS[$formula]}"

  if [[ ! -f "$DEVBOX_INIT" ]]; then
    echo "  warning: $DEVBOX_INIT not found, skipping devbox pin update"
    return
  fi

  local current_pin
  current_pin=$(grep -oP "${var_name}=\"?\K[^\"]*" "$DEVBOX_INIT" 2>/dev/null || true)

  if [[ -z "$current_pin" ]]; then
    echo "  warning: ${var_name} not found in $DEVBOX_INIT"
    return
  fi

  local new_pin="$new_version"
  if [[ "$current_pin" == v* ]]; then
    new_pin="v${new_version#v}"
  else
    new_pin="${new_version#v}"
  fi

  if [[ "$current_pin" == "$new_pin" ]]; then
    return
  fi

  sed -i '' "s|${var_name}=\"${current_pin}\"|${var_name}=\"${new_pin}\"|" "$DEVBOX_INIT"
  echo "  devbox: ${var_name} ${current_pin} → ${new_pin}"
}

commit_devbox_if_changed() {
  if [[ ! -f "$DEVBOX_INIT" ]]; then
    return
  fi
  pushd "$(dirname "$DEVBOX_INIT")" > /dev/null
  if ! git diff --quiet .devbox-init 2>/dev/null; then
    git add .devbox-init
    git commit -m "upgrade devbox tool versions"
    echo "committed .devbox-init"
  fi
  popd > /dev/null
}

for formula in "$@"; do
  echo "upgrading: $formula"
  output=$(brew upgrade "$formula" 2>&1) || true
  echo "$output" | tail -3
  new_version=$(get_brew_version "$formula")
  update_devbox_pin "$formula" "$new_version"
done

commit_devbox_if_changed